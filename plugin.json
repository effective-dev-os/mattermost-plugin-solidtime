{
    "id": "com.mattermost.solidtime",
    "name": "Solidtime",
    "description": "Integrate Solidtime time tracking into Mattermost.",
    "homepage_url": "https://www.solidtime.io/",
    "support_url": "https://github.com/mattermost/mattermost-plugin-solidtime/issues",
    "icon_path": "assets/solidtime-icon.svg",
    "min_server_version": "6.2.1",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "Configure your Solidtime server connection.",
        "footer": "",
        "settings": [
            {
                "key": "SolidtimeServerURL",
                "display_name": "Solidtime Server URL",
                "type": "text",
                "help_text": "Base URL of your Solidtime instance (e.g. https://app.solidtime.io)",
                "placeholder": "https://app.solidtime.io"
            }
        ]
    }
}
